{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "调试 Tanchishe_v2",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/Tanchishe_v2.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": true,
            "MIMode": "gdb",
            "miDebuggerPath": "d:/program files (x86)/mingw/bin/gdb.exe",
            "preLaunchTask": "编译 Tanchishe_v2",
            "setupCommands": [
                {
                    "description": "为 gdb 启用整齐打印",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
